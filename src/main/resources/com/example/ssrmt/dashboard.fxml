<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ssrmt.ui.DashboardController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- 1. Top Banner Panel -->
    <top>
        <HBox alignment="CENTER"  style="-fx-background-color: #003366;">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
            </padding>
            <children>
                <Label text="SMART STUDENT RECORD MANAGEMENT SYSTEM" textFill="WHITE">
                    <font>
                        <Font name="Arial Bold" size="18.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <!-- 2. Left Form Panel -->
    <left>
        <GridPane hgap="10.0" prefWidth="350.0"  style="-fx-border-color: #cccccc; -fx-border-width: 1; -fx-border-style: solid; -fx-border-radius: 5;" vgap="10.0">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
            </padding>
            <children>
                <Label text="Student Data Enrollment" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2">
                    <font>
                        <Font name="Arial Bold" size="14.0" />
                    </font>
                </Label>

                <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtId" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtName" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Email Address:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Label text="Academic Programme:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="txtProgram" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <Label text="Current Level:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <ComboBox fx:id="cmbLevel" maxWidth="1.7976931348623157E308" GridPane.columnIndex="1" GridPane.rowIndex="5">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <Integer fx:value="100" />
                            <Integer fx:value="200" />
                            <Integer fx:value="300" />
                            <Integer fx:value="400" />
                        </FXCollections>
                    </items>
                </ComboBox>

                <Label text="Cumulative GPA:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <TextField fx:id="txtGpa" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                <!-- Control Buttons Panel -->
                <HBox alignment="CENTER" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2">
                    <children>
                        <Button fx:id="btnSave" onAction="#handleSaveStudent" text="Save Record" />
                        <Button fx:id="btnDelete" onAction="#handleDeleteStudent" text="Delete Record" />
                    </children>
                </HBox>
            </children>
        </GridPane>
    </left>

    <!-- 3. Center Panel -->
    <center>
        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets left="10.0" />
            </padding>
            <children>
                <Label text="Active System Records">
                    <font>
                        <Font name="Arial Bold" size="14.0" />
                    </font>
                </Label>
                <TableView fx:id="studentTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>

                    <columns>
                        <TableColumn fx:id="colId" text="ID">
                            <cellValueFactory><PropertyValueFactory property="id" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colName" text="Full Name">
                            <cellValueFactory><PropertyValueFactory property="fullName" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colEmail" text="Email">
                            <cellValueFactory><PropertyValueFactory property="email" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colProgram" text="Programme">
                            <cellValueFactory><PropertyValueFactory property="program" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colLevel" text="Level">
                            <cellValueFactory><PropertyValueFactory property="level" /></cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="colGpa" text="GPA">
                            <cellValueFactory><PropertyValueFactory property="gpa" /></cellValueFactory>
                        </TableColumn>
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
</BorderPane>
